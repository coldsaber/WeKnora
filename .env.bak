# ========== 基础配置 ==========
WEKNORA_VERSION=latest
GIN_MODE=release
LOG_LEVEL=debug
DISABLE_REGISTRATION=false

# ========== 服务连接配置 (外部服务) ==========
# 数据库 (ParadeDB - Phase 2 已部署)
# 使用容器名 WeKnora-postgres 连接
DB_DRIVER=postgres
DB_HOST=WeKnora-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres123!@#
DB_NAME=WeKnora

# 向量检索 (使用 ParadeDB 的 pgvector)
RETRIEVE_DRIVER=postgres

# Redis (1Panel 现有服务)
# 使用 1panel-network 中的别名 'redis'
REDIS_ADDR=redis:6379
# 已从容器信息中自动获取
REDIS_PASSWORD=redis_tzhscS

# MinIO (1Panel 现有服务)
STORAGE_TYPE=minio
# 使用 1panel-network 中的别名 'minio'
MINIO_ENDPOINT=minio:9000
# 已从容器信息中自动获取
MINIO_ACCESS_KEY_ID=minio_inG5Dp
MINIO_SECRET_ACCESS_KEY=minio_yrhbch
MINIO_BUCKET_NAME=weknora
# 浏览器访问的公共地址 (使用 localhost 或宿主机 IP)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Neo4j (1Panel 现有服务 - 用于知识图谱)
# 启用 GraphRAG 功能
ENABLE_GRAPH_RAG=true
NEO4J_ENABLE=true
# 使用 1panel-network 中的别名 'neo4j'
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ocean-bazooka-edison-telecom-china-3277 # 请确认您的 Neo4j 密码

# Ollama (1Panel 现有服务)
# 使用 1panel-network 中的别名 'ollama'
OLLAMA_BASE_URL=http://ollama:11434

# MinerU (Phase 1 已部署 - 用于 PDF 解析)
# 使用容器名 mineru-api 和内部端口 8000
MINERU_ENDPOINT=http://mineru-api:8000

# Jaeger (1Panel 现有服务 - 链路追踪)
# 使用 1panel-network 中的别名 'jaeger'
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=WeKnora
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_PROPAGATORS=tracecontext,baggage

# ========== 应用端口配置 (39000 范围) ==========
APP_HOST=app
# App 后端映射端口
APP_PORT=39001
# 前端映射端口
FRONTEND_PORT=39000
# DocReader 映射端口
DOCREADER_PORT=39002

# 流处理后端配置
STREAM_MANAGER_TYPE=redis
REDIS_DB=0
REDIS_PREFIX=stream:

# 文件存储配置
LOCAL_STORAGE_BASE_DIR=/data/files
AUTO_RECOVER_DIRTY=true

# 安全配置
TENANT_AES_KEY=weknorarag-api-key-secret-secret
JWT_SECRET=weknora-jwt-secret

# 并发配置
CONCURRENCY_POOL_SIZE=5

# DocReader 配置
MAX_FILE_SIZE_MB=50
# 使用 PaddleOCR 引擎
OCR_BACKEND=paddle
# Docreader 并发任务数，PaddleOCR 在高并发下可能异常，建议设为 1
IMAGE_MAX_CONCURRENT=4

# Sandbox 配置
WEKNORA_SANDBOX_MODE=docker
WEKNORA_SANDBOX_TIMEOUT=60
WEKNORA_SANDBOX_DOCKER_IMAGE=wechatopenai/weknora-sandbox:latest
APK_MIRROR_ARG=mirrors.tencent.com
